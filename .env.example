# Copy to .env and fill in. .env is gitignored.

# Optional — real weather data. Leave blank to fall back on FastF1 historical weather.
OPENWEATHER_API_KEY=

# FastF1 cache dir (created on first run)
FASTF1_CACHE_DIR=./fastf1_cache

# Optional — LLM-refined narratives via Claude. When absent, endpoints fall
# back to deterministic template narratives. Either name works; the SDK
# reads ANTHROPIC_API_KEY but we honour CLAUDE_API_KEY as an alias.
ANTHROPIC_API_KEY=
# CLAUDE_API_KEY=

# Optional — override default Claude model. Default: claude-haiku-4-5-20251001
F1_LLM_MODEL=
